rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Estructura legacy (landing original de cainfara): matches/{last|next}
    // Se mantiene intacta para no romper el sitio ya en producción.
    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Estructura nueva multi-jugador: un proyecto Firebase compartido por
    // todas las landings, namespaceado por VITE_PLAYER_SLUG.
    match /players/{slug} {
      allow read: if true;
      allow write: if request.auth != null;

      match /matches/{matchId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}
